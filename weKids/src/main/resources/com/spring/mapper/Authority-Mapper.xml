<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.dao.AuthorityDAO">

    <resultMap id="authorityResultMap" type="com.spring.dto.AuthorityVO">
        <id property="authorityId" column="authority_id"/>
        <result property="memberId" column="member_id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
    </resultMap>

    <select id="selectAuthoritiesByMemberId" parameterType="int" resultMap="authorityResultMap">
        SELECT
            authority_id,
            member_id,
            role_code,
            role_name
        FROM authority
        WHERE member_id = #{memberId}
    </select>

    <select id="selectNextAuthorityId" resultType="int">
        SELECT NVL(MAX(AUTHORITY_ID), 0) + 1 FROM AUTHORITY
    </select>

    <insert id="insertAuthority" parameterType="com.spring.dto.AuthorityVO">
        INSERT INTO AUTHORITY (
            AUTHORITY_ID,
            MEMBER_ID,
            ROLE_CODE,
            ROLE_NAME
        ) VALUES (
            #{authorityId},
            #{memberId},
            #{roleCode},
            #{roleName}
        )
    </insert>

</mapper>
