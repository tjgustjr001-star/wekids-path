<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.dao.MemberDAO">

    <resultMap id="memberResultMap" type="com.spring.dto.MemberVO">
        <id property="member_id" column="member_id"/>
        <result property="login_id" column="login_id"/>
        <result property="pwd" column="pwd"/>
        <result property="email" column="email"/>
        <result property="account_status" column="account_status"/>
        <result property="login_fail_count" column="login_fail_count"/>
        <result property="last_login_at" column="last_login_at"/>
        <result property="locked_at" column="locked_at"/>
        <result property="pwd_changed_at" column="pwd_changed_at"/>
        <result property="created_at" column="created_at"/>
        <result property="updated_at" column="updated_at"/>
    </resultMap>

    <select id="selectMemberByLoginId" parameterType="string" resultMap="memberResultMap">
        SELECT
            member_id,
            login_id,
            pwd,
            email,
            account_status,
            login_fail_count,
            last_login_at,
            locked_at,
            pwd_changed_at,
            created_at,
            updated_at
        FROM member
        WHERE login_id = #{login_id}
    </select>

    <select id="selectNextMemberId" resultType="int">
        SELECT NVL(MAX(MEMBER_ID), 0) + 1 FROM MEMBER
    </select>

    <insert id="insertMember" parameterType="com.spring.dto.MemberVO">
        INSERT INTO MEMBER (
            MEMBER_ID,
            LOGIN_ID,
            PWD,
            EMAIL,
            ACCOUNT_STATUS,
            LOGIN_FAIL_COUNT,
            CREATED_AT,
            UPDATED_AT
        ) VALUES (
            #{member_id},
            #{login_id},
            #{pwd},
            #{email},
            #{account_status},
            0,
            SYSDATE,
            SYSDATE
        )
    </insert>

    <insert id="insertParent" parameterType="com.spring.dto.MemberVO">
        INSERT INTO PARENT (
            PARENT_ID,
            PARENT_NAME,
            BIRTH,
            PHONE,
            CREATED_AT,
            UPDATED_AT
        ) VALUES (
            #{member_id},
            #{name},
            TO_DATE('2000-01-01','YYYY-MM-DD'),
            #{phone},
            SYSDATE,
            SYSDATE
        )
    </insert>

</mapper>