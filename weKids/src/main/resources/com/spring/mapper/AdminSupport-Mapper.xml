<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.dao.admin.AdminSupportDAO">

    <!-- 관리자용 전체 문의 목록 조회 -->
    <select id="selectAllSupports" resultType="com.spring.dto.SupportVO">
        SELECT
            support_id   AS supportNo,
            writer_id    AS writerId,   <!-- 식별을 위해 SELECT에는 유지 -->
            support_type AS category,
            title,
            content,
            status,
            created_at   AS createdAt
        FROM support
        WHERE delete_yn = 0             <!-- 특정인 필터링(WHERE writer_id = ?) 조건 제거 -->
        ORDER BY created_at DESC
    </select>

</mapper>